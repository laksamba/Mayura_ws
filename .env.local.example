# Local Development Environment for WebSocket Server

# For use in local development ONLY
# Copy this to the main app's .env.local to test the standalone WebSocket server locally

# ============================================
# MAIN APP (.env.local in project root)
# ============================================

# Point to local WebSocket server (running on port 3001)
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

# When you deploy to production:
# Change this to your deployed WebSocket server URL:
# NEXT_PUBLIC_WS_URL=wss://retail-websocket.railway.app
# Or: NEXT_PUBLIC_WS_URL=wss://retail-websocket.onrender.com


# ============================================
# WEBSOCKET SERVER (.env in this folder)
# ============================================

# Copy NEXTAUTH_SECRET from main app .env
NEXTAUTH_SECRET=your-secret-key-from-main-app

# Local development port
PORT=3001
NODE_ENV=development
